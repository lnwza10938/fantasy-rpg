{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/src/client/locales/(.*).json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/dev-panel",
      "destination": "/dev.html"
    },
    {
      "source": "/dev-assets",
      "destination": "/dev-assets.html"
    },
    {
      "source": "/dev-map-editor",
      "destination": "/dev-map-editor.html"
    },
    {
      "source": "/dev/map-editor",
      "destination": "/dev-map-editor.html"
    },
    {
      "source": "/dev-assets/slices",
      "destination": "/dev-assets-slices.html"
    },
    {
      "source": "/dev-assets/audio",
      "destination": "/dev-assets-audio.html"
    },
    {
      "source": "/dev-terrain",
      "destination": "/dev-terrain.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/dev(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/vault",
      "destination": "/vault.html"
    },
    {
      "source": "/hub",
      "destination": "/hub.html"
    },
    {
      "source": "/forge",
      "destination": "/forge.html"
    },
    {
      "source": "/adventure",
      "destination": "/adventure.html"
    },
    {
      "source": "/map",
      "destination": "/map.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
